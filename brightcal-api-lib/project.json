{
  "name": "brightcal-api-lib",
  "sourceRoot": "brightcal-api-lib/src",
  "projectType": "library",
  "tags": [
    "type:lib",
    "scope:api"
  ],
  "implicitDependencies": [
    "brightcal-lib",
    "brightchain-api-lib",
    "brightchain-db"
  ],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/brightcal-api-lib",
        "main": "brightcal-api-lib/src/index.ts",
        "tsConfig": "brightcal-api-lib/tsconfig.lib.json",
        "assets": [
          {
            "input": "brightcal-api-lib",
            "glob": "*.md",
            "output": "."
          }
        ]
      },
      "configurations": {
        "development": {},
        "production": {}
      }
    },
    "publish": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm publish --access public",
        "cwd": "dist/brightcal-api-lib"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "brightcal-api-lib/jest.config.cts",
        "passWithNoTests": true
      },
      "configurations": {
        "ci": {
          "ci": true,
          "codeCoverage": true
        }
      }
    }
  }
}
