{
  "name": "@brightchain/db",
  "version": "0.29.26",
  "description": "MongoDB-like document database driver backed by BrightChain block store",
  "license": "MIT",
  "main": "./src/index.js",
  "types": "./src/index.ts",
  "files": [
    "src",
    "README.md"
  ],
  "dependencies": {
    "@noble/hashes": "^1.8.0",
    "tslib": "^2.8.1"
  },
  "peerDependencies": {
    "@brightchain/brightchain-lib": "^0.29.26",
    "@digitaldefiance/branded-interface": "0.0.5",
    "@digitaldefiance/node-express-suite": "4.26.9",
    "express": ">=5.0.0"
  },
  "scripts": {
    "build:dev": "npx nx build brightchain-db --configuration=development",
    "build:prod": "npx nx build brightchain-db --configuration=production",
    "lint": "npx nx lint brightchain-db",
    "lint:fix": "npx nx lint brightchain-db --fix",
    "test": "NODE_ENV=development npx nx test brightchain-db --configuration=development --outputStyle=stream 2>&1",
    "test:dev:16": "NODE_ENV=development npx nx test brightchain-db --maxWorkers=16 --parallel=16 --configuration=development --outputStyle=stream 2>&1",
    "test:dev:16:logged": "NODE_ENV=development npx nx test brightchain-db --maxWorkers=16 --parallel=16 --configuration=development --outputStyle=stream 2>&1 | ansifilter -o test.log"
  },
  "devDependencies": {
    "@types/express": "^5.0.6"
  }
}
