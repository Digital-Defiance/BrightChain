{
  "name": "brightmail-react-components",
  "$schema": "../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "brightmail-react-components/src",
  "projectType": "library",
  "tags": ["type:lib", "scope:frontend"],
  "implicitDependencies": ["brightchain-lib"],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/brightmail-react-components",
        "main": "brightmail-react-components/src/index.ts",
        "tsConfig": "brightmail-react-components/tsconfig.lib.json",
        "assets": [
          {
            "input": "brightmail-react-components",
            "glob": "*.md",
            "output": "."
          }
        ]
      },
    },
    "publish": {
      "command": "node tools/scripts/publish.mjs brightmail-react-components {args.ver} {args.tag}",
      "dependsOn": ["build"]
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "brightmail-react-components/jest.config.cts"
      }
    }
  }
}
