DEFAULT_YARN_VERSION=4.14.1
DEFAULT_NVM_VERSION=22
FONTAWESOME_KEY=xxxxxx
CODACY_PROJECT_TOKEN=xxxxxx
GRAPHITE_KEY=xxxxxx

COMPOSE_PROJECT_NAME=brightchain_devcontainer

DEBUG="false"

AWS_ACCESS_KEY_ID=XXXXX
AWS_SECRET_ACCESS_KEY=xxxxx
AWS_REGION=us-west-2

# ─── UPnP Configuration ─────────────────────────────────────────────────
# Enable/disable UPnP automatic port forwarding (default: false)
UPNP_ENABLED=false
# HTTP/Express port to map externally (default: 3000)
UPNP_HTTP_PORT=3000
# WebSocket port to map externally (default: 3000, same as HTTP)
UPNP_WEBSOCKET_PORT=3000
# Port mapping time-to-live in seconds (default: 3600 = 1 hour, min: 60)
UPNP_TTL=3600
# Mapping refresh interval in milliseconds (default: 1800000 = 30 minutes, must be < TTL*1000)
UPNP_REFRESH_INTERVAL=1800000
# UPnP protocol: upnp | natpmp | auto (default: auto)
UPNP_PROTOCOL=auto
# Number of retry attempts on failure (default: 3, range: 1-10)
UPNP_RETRY_ATTEMPTS=3
# Delay between retries in milliseconds (default: 5000, range: 1000-60000)
UPNP_RETRY_DELAY=5000

# ─── Email Gateway Configuration ─────────────────────────────────────────────
# Canonical email domain for this BrightChain instance
EMAIL_DOMAIN=brightchain.org

# Postfix connection
GATEWAY_POSTFIX_HOST=localhost
GATEWAY_POSTFIX_PORT=25
# GATEWAY_POSTFIX_USER=
# GATEWAY_POSTFIX_PASS=

# DKIM signing
GATEWAY_DKIM_KEY_PATH=/etc/dkim/private.key
GATEWAY_DKIM_SELECTOR=default

# Inbound processing — Mail Drop Directory (Maildir format)
GATEWAY_MAIL_DROP_DIR=/var/spool/brightchain/incoming/
GATEWAY_ERROR_DIR=/var/spool/brightchain/errors/
GATEWAY_MAX_MESSAGE_SIZE=26214400

# Recipient Lookup Service (socketmap for Postfix)
GATEWAY_LOOKUP_PORT=2526
GATEWAY_LOOKUP_CACHE_TTL=300

# Anti-spam engine: spamassassin or rspamd
GATEWAY_SPAM_ENGINE=spamassassin
GATEWAY_SPAM_PROBABLE=5.0
GATEWAY_SPAM_DEFINITE=10.0

# Outbound queue & retry
GATEWAY_QUEUE_CONCURRENCY=10
GATEWAY_RETRY_MAX_COUNT=5
GATEWAY_RETRY_MAX_DURATION=172800000
GATEWAY_RETRY_BASE_INTERVAL=60000

# ─── Email Gateway Test Mode ─────────────────────────────────────────────────
# Enable test mode for local development (no real DNS/MX required)
GATEWAY_TEST_MODE=true

# Capture outbound mail to filesystem instead of SMTP delivery
GATEWAY_TEST_CATCHALL=true
GATEWAY_TEST_CATCHALL_DIR=/var/spool/brightchain/catchall/

# Skip DKIM signing (useful when no real key available)
GATEWAY_TEST_SKIP_DKIM=true

# Skip spam filtering (useful when SpamAssassin/Rspamd not running)
GATEWAY_TEST_SKIP_SPAM=true

# Accept all recipients without querying lookup service
GATEWAY_TEST_ACCEPT_ALL_RECIPIENTS=true

# Comma-separated list of test recipients always accepted
# GATEWAY_TEST_RECIPIENTS=alice@brightchain.org,bob@brightchain.org
