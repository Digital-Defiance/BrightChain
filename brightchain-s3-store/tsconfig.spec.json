{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../dist/out-tsc",
    "module": "esnext",
    "types": ["jest", "node"]
  },
  "include": [
    "jest.config.ts",
    "src/**/__tests__/*.ts",
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "src/**/*.mock.ts",
    "src/**/*.d.ts",
    "src/**/*.ts"
  ],
  "files": ["src/test-setup.ts"]
}
