{
  "name": "@brightchain/brightchain-lib",
  "version": "0.29.27",
  "description": "BrightChain core library - browser-compatible blockchain storage",
  "main": "src/index.js",
  "types": "src/index.d.ts",
  "browser": "src/browser.js",
  "files": [
    "src",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "browser": "./src/browser.js",
      "import": "./src/index.js",
      "require": "./src/index.js"
    },
    "./browser": {
      "types": "./src/browser.d.ts",
      "import": "./src/browser.js",
      "require": "./src/browser.js"
    },
    "./lib/db/cursor": {
      "types": "./src/lib/db/cursor.d.ts",
      "import": "./src/lib/db/cursor.js",
      "require": "./src/lib/db/cursor.js"
    },
    "./lib/db/updateEngine": {
      "types": "./src/lib/db/updateEngine.d.ts",
      "import": "./src/lib/db/updateEngine.js",
      "require": "./src/lib/db/updateEngine.js"
    },
    "./lib/db/transaction": {
      "types": "./src/lib/db/transaction.d.ts",
      "import": "./src/lib/db/transaction.js",
      "require": "./src/lib/db/transaction.js"
    },
    "./lib/db/inMemoryHeadRegistry": {
      "types": "./src/lib/db/inMemoryHeadRegistry.d.ts",
      "import": "./src/lib/db/inMemoryHeadRegistry.js",
      "require": "./src/lib/db/inMemoryHeadRegistry.js"
    },
    "./lib/db/indexing": {
      "types": "./src/lib/db/indexing.d.ts",
      "import": "./src/lib/db/indexing.js",
      "require": "./src/lib/db/indexing.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Digital-Defiance/BrightChain.git",
    "directory": "brightchain-lib"
  },
  "homepage": "https://github.com/Digital-Defiance/BrightChain#readme",
  "bugs": {
    "url": "https://github.com/Digital-Defiance/BrightChain/issues"
  },
  "keywords": [
    "blockchain",
    "encryption",
    "storage",
    "decentralized",
    "brightchain"
  ],
  "author": "Digital Defiance",
  "license": "MIT",
  "dependencies": {
    "@digitaldefiance/branded-interface": "0.0.5",
    "@digitaldefiance/bzip2-wasm": "^1.1.1",
    "@digitaldefiance/ecies-lib": "5.1.4",
    "@digitaldefiance/i18n-lib": "4.7.3",
    "@digitaldefiance/reed-solomon-erasure.wasm": "^1.0.2",
    "@digitaldefiance/secrets": "^2.0.7",
    "@digitaldefiance/suite-core-lib": "4.26.8",
    "@ethereumjs/wallet": "^10.0.0",
    "@noble/hashes": "^1.8.0",
    "@peculiar/asn1-pfx": "^2.6.1",
    "@peculiar/x509": "^2.0.0",
    "@scure/bip32": "^1.7.0",
    "@scure/bip39": "^1.6.0",
    "asn1js": "^3.0.7",
    "blakejs": "^1.2.1",
    "currency-codes": "^2.2.0",
    "elliptic": "^6.6.1",
    "email-addresses": "^5.0.0",
    "express": ">=5.0.0",
    "nat-pmp": "^1.0.0",
    "nat-upnp": "^1.1.1",
    "openpgp": "^6.3.0",
    "otpauth": "^9.5.0",
    "paillier-bigint": "^3.4.3",
    "pkijs": "^3.4.0",
    "postal-mime": "^2.7.4",
    "qrcode": "^1.5.4",
    "secp256k1": "^5.0.1",
    "ts-brand": "^0.2.0",
    "tslib": "^2.3.0",
    "uuid": "11.0.5",
    "validator": "^13.15.0"
  },
  "devDependencies": {
    "@jest/environment": "^30.3.0",
    "@jest/globals": "^30.3.0",
    "@noble/curves": "^1.9.0",
    "@types/elliptic": "^6.4.18",
    "@types/express": "^5.0.6",
    "@types/nat-upnp": "^1.1.5",
    "@types/qrcode": "^1.5.6",
    "@types/secp256k1": "^4.0.7",
    "@types/uuid": "^9.0.7",
    "@types/validator": "^13.15.10",
    "expect": "^30.3.0",
    "jest-environment-node": "^30.3.0",
    "jest-mock": "^30.3.0"
  },
  "type": "commonjs",
  "sideEffects": [
    "src/lib/init.ts",
    "src/lib/enumeration-translations/blockSize.ts",
    "src/lib/enumeration-translations/blockType.ts",
    "src/lib/enumeration-translations/brightTrustDataRecordAction.ts",
    "src/lib/enumeration-translations/memberStatusType.ts",
    "src/lib/enumeration-translations/memberType.ts",
    "src/lib/enumeration-translations/security-event-severity.ts",
    "src/lib/enumeration-translations/security-event-type.ts",
    "src/lib/interfaces/branded/primitives/blockId.ts",
    "src/lib/interfaces/branded/primitives/emailString.ts",
    "src/lib/interfaces/branded/primitives/iso8601Timestamp.ts",
    "src/lib/interfaces/branded/primitives/poolId.ts",
    "src/lib/interfaces/branded/primitives/shortHexGuid.ts"
  ],
  "scripts": {
    "build:dev": "npx nx build brightchain-lib --configuration=development",
    "build:prod": "npx nx build brightchain-lib --configuration=production",
    "lint": "npx eslint '**/*.{ts,tsx}'",
    "lint:fix": "npx eslint '**/*.{ts,tsx}' --fix",
    "test:dev:16": "NODE_ENV=development npx nx test brightchain-lib --maxWorkers=16 --parallel=16 --configuration=development --outputStyle=stream 2>&1",
    "test:dev:16:logged": "NODE_ENV=development npx nx test brightchain-lib --maxWorkers=16 --parallel=16 --configuration=development --outputStyle=stream 2>&1 | ansifilter -o test.log"
  }
}
