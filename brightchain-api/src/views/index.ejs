<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title><%= title %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/x-icon" href="/assets/favicon.ico" />
    <script nonce="<%= cspNonce %>"></script>
    <base href="<%= baseHref %>" />
    <script nonce="<%= cspNonce %>">
      window.APP_CONFIG = {
        apiUrl: '<%= siteUrl %>/api',
        serverUrl: '<%= siteUrl %>',
        hostname: '<%= hostname %>',
        siteTitle: '<%= title %>',
        server: '<%= server %>',
        emailDomain: '<%= emailDomain %>'
      };
    </script>
    <% if (cssFile) { %>
    <link rel="stylesheet" href="<%= cssFile %>" />
    <% } %>
    <% if (typeof webpackCss !== 'undefined' && webpackCss && webpackCss.length > 0) { %>
    <% webpackCss.forEach(function(css) { %>
    <link rel="stylesheet" href="static/js/<%= css %>" />
    <% }); %>
    <% } %>
    <script nonce="<%= cspNonce %>" src="https://kit.fontawesome.com/<%= fontAwesomeKitId %>.js" crossorigin="anonymous"></script>
  </head>
  <body>
    <div id="root"></div>
    <% if (jsFile) { %>
    <%/* Production: single hashed bundle */%>
    <script nonce="<%= cspNonce %>" type="module" src="<%= jsFile %>"></script>
    <% } else if (devScripts && devScripts.length > 0) { %>
    <%/* Dev: un-hashed runtime/main/vendor chunks served from /static/js/ */%>
    <% devScripts.forEach(function(script) { %>
    <script nonce="<%= cspNonce %>" type="module" src="static/js/<%= script %>"></script>
    <% }); %>
    <% } %>
  </body>
</html>
