{
  "name": "@brightchain/brighthub-react-components",
  "version": "0.25.0",
  "description": "React components for BrightHub social network module",
  "main": "./index.js",
  "module": "./index.mjs",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.mjs",
      "require": "./index.js"
    },
    "./theme": {
      "types": "./lib/theme/index.d.ts",
      "import": "./lib/theme/index.mjs",
      "require": "./lib/theme/index.js"
    }
  },
  "peerDependencies": {
    "@emotion/react": ">=11.0.0",
    "@emotion/styled": ">=11.0.0",
    "@mui/material": ">=5.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "keywords": [
    "brighthub",
    "brightchain",
    "social-network",
    "react-components"
  ]
}
