{
  "name": "brightpass-react-components",
  "$schema": "../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "brightpass-react-components/src",
  "projectType": "library",
  "tags": ["type:lib", "scope:frontend"],
  "implicitDependencies": ["brightchain-lib", "brightchain-react-components"],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/brightpass-react-components",
        "main": "brightpass-react-components/src/index.ts",
        "tsConfig": "brightpass-react-components/tsconfig.lib.json",
        "assets": [
          {
            "input": "brightpass-react-components",
            "glob": "*.md",
            "output": "."
          }
        ]
      },
      "configurations": {
        "development": {},
        "production": {}
      }
    },
    "publish": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm publish --access public",
        "cwd": "dist/brightpass-react-components"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "brightpass-react-components/jest.config.cts"
      }
    }
  }
}
