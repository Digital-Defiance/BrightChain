{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../dist/brightchain-lib",
    "declaration": true,
    "declarationMap": true,
    "composite": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "types": ["node"],
    "paths": {
      "@brightchain/brightdate": ["../dist/brightdate/src/index.d.ts"],
      "@brightchain/brightdate/*": ["../dist/brightdate/src/*"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["jest.config.ts", "src/**/*.spec.ts", "src/**/*.test.ts"]
}
