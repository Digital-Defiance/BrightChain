{
  "name": "brightchain-s3-store",
  "$schema": "../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "brightchain-s3-store/src",
  "projectType": "library",
  "tags": ["type:lib", "scope:cloud"],
  "implicitDependencies": ["brightchain-lib", "brightchain-api-lib"],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/brightchain-s3-store",
        "main": "brightchain-s3-store/src/index.ts",
        "tsConfig": "brightchain-s3-store/tsconfig.lib.json",
        "assets": [
          {
            "input": "brightchain-s3-store",
            "glob": "*.md",
            "output": "."
          }
        ]
      },
      "dependsOn": ["^build"],
      "configurations": {
        "development": {},
        "production": {}
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "brightchain-s3-store/jest.config.ts",
        "passWithNoTests": true
      },
      "cache": true
    },
    "publish": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm publish --access public",
        "cwd": "dist/brightchain-s3-store"
      }
    }
  }
}
