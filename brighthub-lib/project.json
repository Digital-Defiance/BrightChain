{
  "name": "brighthub-lib",
  "$schema": "../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "brighthub-lib/src",
  "projectType": "library",
  "tags": ["type:lib", "scope:brighthub"],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/brighthub-lib",
        "main": "brighthub-lib/src/index.ts",
        "tsConfig": "brighthub-lib/tsconfig.lib.json",
        "assets": [
          {
            "input": "brighthub-lib",
            "glob": "*.md",
            "output": "."
          }
        ]
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": ["brighthub-lib/**/*.ts"]
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "brighthub-lib/jest.config.cts"
      }
    }
  }
}
