#!/usr/bin/env bash
#
# Pre-commit hook: blocks commits containing "burnbag", "phix", or "gild"
# (case-insensitive) in staged file paths or content.
#
# Override: git commit --no-verify
# Or set: ALLOW_SECRETS=1 git commit
#

set -euo pipefail

# Escape hatch via environment variable
if [ "${ALLOW_SECRETS:-0}" = "1" ]; then
  exit 0
fi

# Pattern matching any of the blocked terms (case-insensitive)
BLOCKED_PATTERN='burnbag|phix|gild'

# Check staged files for blocked terms in both filenames/paths AND content
PATH_VIOLATIONS=""
CONTENT_VIOLATIONS=""

while IFS= read -r -d '' file; do
  # Check if the filename/path itself contains a blocked term (case-insensitive)
  if echo "$file" | grep -iqE "$BLOCKED_PATTERN"; then
    PATH_VIOLATIONS="${PATH_VIOLATIONS}  ${file}\n"
    continue
  fi

  # Check staged content of this file for blocked terms (case-insensitive)
  if git diff --cached --diff-filter=d -- "$file" | grep -iqE "$BLOCKED_PATTERN"; then
    CONTENT_VIOLATIONS="${CONTENT_VIOLATIONS}  ${file}\n"
  fi
done < <(git diff --cached --name-only --diff-filter=d -z)

VIOLATIONS="${PATH_VIOLATIONS}${CONTENT_VIOLATIONS}"

if [ -n "$VIOLATIONS" ]; then
  echo ""
  echo "🚫 BLOCKED: Staged changes contain 'burnbag', 'phix', or 'gild' references:"
  echo ""
  if [ -n "$PATH_VIOLATIONS" ]; then
    echo "Files with blocked terms in their path:"
    echo -e "$PATH_VIOLATIONS"
  fi
  if [ -n "$CONTENT_VIOLATIONS" ]; then
    echo "Files with blocked terms in their content:"
    echo -e "$CONTENT_VIOLATIONS"
  fi
  echo "These are trade secret projects. Only name references in"
  echo "submodule wiring files are permitted in the public repo."
  echo ""
  echo "To override (use with caution):"
  echo "  git commit --no-verify"
  echo "  ALLOW_SECRETS=1 git commit"
  echo ""
  exit 1
fi
