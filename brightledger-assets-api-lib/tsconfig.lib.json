{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../dist/brightledger-assets-api-lib",
    "declaration": true,
    "declarationMap": true,
    "composite": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "types": [
      "node"
    ]
  },
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "jest.config.ts",
    "src/**/*.spec.ts",
    "src/**/*.test.ts"
  ],
  "references": [
    {
      "path": "../brightchain-lib/tsconfig.lib.json"
    },
    {
      "path": "../brightledger-assets-lib/tsconfig.lib.json"
    }
  ]
}