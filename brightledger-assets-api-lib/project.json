{
  "name": "brightledger-assets-api-lib",
  "$schema": "../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "brightledger-assets-api-lib/src",
  "projectType": "library",
  "tags": [
    "type:lib",
    "scope:node-only",
    "scope:brightledger"
  ],
  "implicitDependencies": [
    "brightchain-lib",
    "brightledger-assets-lib"
  ],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": [
        "{options.outputPath}"
      ],
      "options": {
        "outputPath": "dist/brightledger-assets-api-lib",
        "main": "brightledger-assets-api-lib/src/index.ts",
        "tsConfig": "brightledger-assets-api-lib/tsconfig.lib.json",
        "assets": [
          {
            "input": "brightledger-assets-api-lib",
            "glob": "*.md",
            "output": "."
          },
          {
            "input": "brightledger-assets-api-lib",
            "glob": "package.json",
            "output": "."
          }
        ]
      },
      "configurations": {
        "development": {},
        "production": {}
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": [
        "{workspaceRoot}/coverage/{projectRoot}"
      ],
      "options": {
        "jestConfig": "brightledger-assets-api-lib/jest.config.cts",
        "passWithNoTests": true
      }
    }
  }
}
