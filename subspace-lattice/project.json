{
  "name": "subspace-lattice",
  "$schema": "../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "subspace-lattice/src",
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/subspace-lattice",
        "main": "subspace-lattice/src/index.ts",
        "tsConfig": "subspace-lattice/tsconfig.lib.json"
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "subspace-lattice/jest.config.ts"
      }
    }
  }
}
