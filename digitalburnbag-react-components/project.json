{
  "name": "digitalburnbag-react-components",
  "sourceRoot": "digitalburnbag-react-components/src",
  "projectType": "library",
  "tags": ["type:lib", "scope:frontend"],
  "implicitDependencies": ["brightchain-lib", "brightchain-react-components"],
  "targets": {
    "build": {
      "executor": "@nx/vite:build",
      "outputs": ["{options.outputPath}"],
      "defaultConfiguration": "production",
      "options": {
        "outputPath": "dist/digitalburnbag-react-components"
      },
      "configurations": {
        "development": {
          "mode": "development"
        },
        "production": {
          "mode": "production"
        }
      }
    },
    "publish": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm publish --access public",
        "cwd": "dist/digitalburnbag-react-components"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "digitalburnbag-react-components/jest.config.cts"
      }
    },
    "e2e": {
      "executor": "@nx/playwright:playwright",
      "outputs": ["{workspaceRoot}/test-results/{projectRoot}"],
      "dependsOn": ["brightchain-api:build", "brightchain-react:build"],
      "options": {
        "config": "digitalburnbag-react-components/playwright.config.ts"
      },
      "parallelism": false
    }
  }
}
