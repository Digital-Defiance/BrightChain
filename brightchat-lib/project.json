{
  "name": "brightchat-lib",
  "$schema": "../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "brightchat-lib/src",
  "projectType": "library",
  "tags": [
    "type:lib",
    "scope:shared"
  ],
  "implicitDependencies": [
    "brightchain-lib"
  ],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": [
        "{options.outputPath}"
      ],
      "options": {
        "outputPath": "dist/brightchat-lib",
        "main": "brightchat-lib/src/index.ts",
        "tsConfig": "brightchat-lib/tsconfig.lib.json",
        "assets": [
          {
            "input": "brightchat-lib",
            "glob": "*.md",
            "output": "."
          }
        ]
      },
      "configurations": {
        "development": {},
        "production": {}
      }
    },
    "publish": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm publish --access public",
        "cwd": "dist/brightchat-lib"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": [
        "{workspaceRoot}/coverage/{projectRoot}"
      ],
      "options": {
        "jestConfig": "brightchat-lib/jest.config.ts"
      }
    }
  }
}
